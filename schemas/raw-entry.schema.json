{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evalrank.ai/schemas/raw-entry.schema.json",
  "title": "EvalRank Raw Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "object",
    "source",
    "source_id",
    "entity_kind",
    "canonical_id",
    "raw_metadata",
    "declared_capability_shape",
    "fetched_at",
    "content_hash"
  ],
  "properties": {
    "object": {
      "const": "raw_entry"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "source_id": {
      "type": "string",
      "minLength": 1
    },
    "entity_kind": {
      "type": "string",
      "minLength": 1
    },
    "canonical_id": {
      "type": "string",
      "minLength": 1
    },
    "raw_metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "declared_capability_shape": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": true
    },
    "fetched_at": {
      "type": "string",
      "minLength": 1
    },
    "content_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
