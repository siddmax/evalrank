{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evalrank.ai/schemas/evidence-item.schema.json",
  "title": "EvalRank Evidence Item",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_id",
    "subject",
    "kind",
    "source",
    "observed_at",
    "summary",
    "score",
    "metadata"
  ],
  "properties": {
    "evidence_id": {
      "type": "string",
      "minLength": 1
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entity_type",
        "id"
      ],
      "properties": {
        "entity_type": {
          "type": "string",
          "minLength": 1
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "kind": {
      "type": "string",
      "enum": [
        "attestation",
        "benchmark",
        "documentation",
        "runtime-observation",
        "trace"
      ]
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "observed_at": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "score": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
