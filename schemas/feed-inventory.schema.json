{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evalrank.ai/schemas/feed-inventory.schema.json",
  "title": "EvalRank Feed Inventory V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "object",
    "schema_version",
    "manifest_version",
    "feeds"
  ],
  "properties": {
    "$schema": {
      "const": "../schemas/feed-inventory.schema.json"
    },
    "object": {
      "const": "evalrank_feed_inventory"
    },
    "schema_version": {
      "const": "1"
    },
    "manifest_version": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}\\.[1-9]\\d*$"
    },
    "feeds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/FeedInventoryEntry"
      }
    }
  },
  "$defs": {
    "FeedInventoryEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "benchmark_family",
        "feed",
        "research"
      ],
      "properties": {
        "benchmark_family": {
          "$ref": "https://evalrank.ai/schemas/evalrank-manifest.schema.json#/$defs/BenchmarkFamily"
        },
        "feed": {
          "$ref": "https://evalrank.ai/schemas/evalrank-manifest.schema.json#/$defs/Feed"
        },
        "research": {
          "$ref": "https://evalrank.ai/schemas/benchmark-research-provenance.schema.json#/$defs/BenchmarkFamilyResearch"
        }
      }
    }
  }
}
