{
  "openapi": "3.1.1",
  "info": {
    "title": "EvalRank Public API",
    "version": "0.0.0",
    "description": "Public contract for portable EvalRank evaluation surfaces. This file does not declare a live hosted service."
  },
  "tags": [
    {
      "name": "recommendations",
      "description": "Evaluate a public request payload and return a recommendation payload."
    },
    {
      "name": "metadata",
      "description": "Read public EvalRank metadata contracts."
    }
  ],
  "paths": {
    "/v1/use-cases": {
      "get": {
        "tags": [
          "metadata"
        ],
        "operationId": "listUseCases",
        "summary": "List public use cases",
        "description": "Contract-only public taxonomy route. Benchmark weights, scorer behavior, storage, and hosted deployment details are intentionally outside this file.",
        "responses": {
          "200": {
            "description": "Public use-case taxonomy catalog.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UseCaseCatalog"
                }
              }
            }
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "503": {
            "$ref": "#/components/responses/ServiceUnavailable"
          }
        }
      }
    },
    "/v1/scoring-stages": {
      "get": {
        "tags": [
          "metadata"
        ],
        "operationId": "listScoringStages",
        "summary": "List public scoring stages",
        "description": "Contract-only public scoring-stage catalog route. Formulas, thresholds, scorer behavior, storage, and hosted deployment details are intentionally outside this file.",
        "responses": {
          "200": {
            "description": "Public scoring-stage catalog.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScoringStageCatalog"
                }
              }
            }
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "503": {
            "$ref": "#/components/responses/ServiceUnavailable"
          }
        }
      }
    },
    "/v1/recommendations": {
      "post": {
        "tags": [
          "recommendations"
        ],
        "operationId": "evaluateRecommendation",
        "summary": "Evaluate a request into a recommendation",
        "description": "Contract-only public route shape. Runtime auth, scorer behavior, storage, receipt IDs, and deployment details are intentionally outside this file.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EvaluationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Recommendation generated for the request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Recommendation"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/InvalidEvaluationRequest"
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "503": {
            "$ref": "#/components/responses/RecommendationNotPublished"
          },
          "504": {
            "$ref": "#/components/responses/UpstreamTimeout"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "EvaluationRequest": {
        "$ref": "evaluation-request.schema.json"
      },
      "Recommendation": {
        "$ref": "recommendation.schema.json"
      },
      "UseCaseCatalog": {
        "$ref": "use-case-catalog.schema.json"
      },
      "ScoringStageCatalog": {
        "$ref": "scoring-stage-catalog.schema.json"
      },
      "ProblemDetails": {
        "$ref": "problem.schema.json"
      }
    },
    "headers": {
      "RequestId": {
        "description": "Opaque request correlation identifier for support and retry diagnostics.",
        "schema": {
          "type": "string",
          "minLength": 1
        }
      },
      "RetryAfter": {
        "description": "Seconds clients should wait before retrying a retriable request.",
        "schema": {
          "type": "integer",
          "minimum": 0
        }
      },
      "RateLimit": {
        "description": "Current rate-limit state using the IETF HTTPAPI RateLimit header field shape.",
        "schema": {
          "type": "string",
          "minLength": 1
        }
      },
      "RateLimitPolicy": {
        "description": "Advertised quota policy using the IETF HTTPAPI RateLimit-Policy header field shape.",
        "schema": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "responses": {
      "InvalidEvaluationRequest": {
        "description": "The request body is malformed or does not conform to EvaluationRequest.",
        "headers": {
          "X-Request-Id": {
            "$ref": "#/components/headers/RequestId"
          }
        },
        "content": {
          "application/problem+json": {
            "schema": {
              "allOf": [
                {
                  "$ref": "#/components/schemas/ProblemDetails"
                },
                {
                  "type": "object",
                  "required": [
                    "status",
                    "code",
                    "retriable"
                  ],
                  "properties": {
                    "status": {
                      "const": 400
                    },
                    "code": {
                      "const": "invalid_evaluation_request"
                    },
                    "retriable": {
                      "const": false
                    }
                  }
                }
              ]
            }
          }
        }
      },
      "BadRequest": {
        "description": "Malformed request payload.",
        "headers": {
          "X-Request-Id": {
            "$ref": "#/components/headers/RequestId"
          }
        },
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ProblemDetails"
            }
          }
        }
      },
      "ValidationError": {
        "description": "Request payload was syntactically valid but failed public contract validation.",
        "headers": {
          "X-Request-Id": {
            "$ref": "#/components/headers/RequestId"
          }
        },
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ProblemDetails"
            }
          }
        }
      },
      "RateLimited": {
        "description": "Request was rate limited and may be retried after the advertised delay.",
        "headers": {
          "X-Request-Id": {
            "$ref": "#/components/headers/RequestId"
          },
          "Retry-After": {
            "$ref": "#/components/headers/RetryAfter"
          },
          "RateLimit": {
            "$ref": "#/components/headers/RateLimit"
          },
          "RateLimit-Policy": {
            "$ref": "#/components/headers/RateLimitPolicy"
          }
        },
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ProblemDetails"
            }
          }
        }
      },
      "ServiceUnavailable": {
        "description": "Service is temporarily unavailable or methodology data is stale.",
        "headers": {
          "X-Request-Id": {
            "$ref": "#/components/headers/RequestId"
          },
          "Retry-After": {
            "$ref": "#/components/headers/RetryAfter"
          }
        },
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ProblemDetails"
            }
          }
        }
      },
      "RecommendationNotPublished": {
        "description": "The legacy recommendation operation is temporarily unavailable while the deterministic decision contract is prepared.",
        "headers": {
          "X-Request-Id": {
            "$ref": "#/components/headers/RequestId"
          },
          "Retry-After": {
            "$ref": "#/components/headers/RetryAfter"
          }
        },
        "content": {
          "application/problem+json": {
            "schema": {
              "allOf": [
                {
                  "$ref": "#/components/schemas/ProblemDetails"
                },
                {
                  "type": "object",
                  "required": [
                    "status",
                    "code",
                    "retriable"
                  ],
                  "properties": {
                    "status": {
                      "const": 503
                    },
                    "code": {
                      "const": "recommendation_not_published"
                    },
                    "retriable": {
                      "const": true
                    }
                  }
                }
              ]
            }
          }
        }
      },
      "UpstreamTimeout": {
        "description": "Upstream evaluation dependency timed out.",
        "headers": {
          "X-Request-Id": {
            "$ref": "#/components/headers/RequestId"
          },
          "Retry-After": {
            "$ref": "#/components/headers/RetryAfter"
          }
        },
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ProblemDetails"
            }
          }
        }
      }
    }
  }
}
