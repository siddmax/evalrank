{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evalrank.ai/schemas/scoring-stage-catalog.schema.json",
  "title": "EvalRank Scoring Stage Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "object",
    "methodology_version",
    "generated_at",
    "stages"
  ],
  "properties": {
    "object": {
      "const": "scoring_stage_catalog"
    },
    "methodology_version": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}\\.[1-9]\\d*\\.([a-z0-9]+-)*[a-z0-9]+$"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/ScoringStage"
      }
    }
  },
  "$defs": {
    "ScoringStage": {
      "title": "ScoringStage",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "ordinal",
        "name",
        "description",
        "input_contracts",
        "output_contracts",
        "public_boundary"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "ordinal": {
          "type": "integer",
          "minimum": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "input_contracts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "output_contracts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "public_boundary": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
