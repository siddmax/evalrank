{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evalrank.ai/schemas/problem.schema.json",
  "title": "EvalRank Problem Details",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "type",
    "title",
    "status",
    "detail"
  ],
  "properties": {
    "type": {
      "type": "string",
      "format": "uri-reference",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "integer",
      "minimum": 400,
      "maximum": 599
    },
    "detail": {
      "type": "string",
      "minLength": 1
    },
    "instance": {
      "type": "string",
      "format": "uri-reference",
      "minLength": 1
    },
    "code": {
      "type": "string",
      "enum": [
        "rate_limited",
        "upstream_timeout",
        "validation",
        "not_found",
        "methodology_stale",
        "internal",
        "unauthorized",
        "forbidden"
      ]
    },
    "retriable": {
      "type": "boolean"
    },
    "retry_after": {
      "type": "integer",
      "minimum": 0
    },
    "field": {
      "type": "string",
      "minLength": 1
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "doc_url": {
      "type": "string",
      "format": "uri-reference",
      "pattern": "^https?://"
    }
  }
}
