{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evalrank.ai/schemas/decision-query.schema.json",
  "title": "EvalRank Decision Query V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "object",
    "schema_version",
    "cell_id",
    "ranking_group_id",
    "entity_kind",
    "interaction_policy",
    "configuration_passport_class",
    "objective"
  ],
  "properties": {
    "object": { "const": "decision_query" },
    "schema_version": { "const": "1" },
    "cell_id": { "$ref": "#/$defs/NonEmptyString" },
    "ranking_group_id": { "$ref": "#/$defs/NonEmptyString" },
    "entity_kind": {
      "enum": ["model_configuration", "agent_system", "system_configuration", "component_configuration", "arena_system"]
    },
    "interaction_policy": {
      "enum": ["direct_prompt", "agentic", "system", "retrieval", "crowd_pairwise"]
    },
    "configuration_passport_class": {
      "enum": ["model-configuration-v1", "agent-system-v1", "system-configuration-v1", "component-configuration-v1", "arena-system-v1"]
    },
    "objective": { "enum": ["capability_top_set", "lowest_cost_within_top_set"] },
    "provider_ids": { "$ref": "#/$defs/NonEmptyStringSet" },
    "regions": { "$ref": "#/$defs/NonEmptyStringSet" },
    "minimum_context_tokens": { "$ref": "#/$defs/PositiveSafeInteger" },
    "usage_profile": { "$ref": "#/$defs/UsageProfile" },
    "zero_cache_sensitivity_usage_profile": { "$ref": "#/$defs/UsageProfile" },
    "monthly_budget_microusd": { "$ref": "#/$defs/NonNegativeSafeInteger" }
  },
  "allOf": [
    {
      "oneOf": [
        { "properties": { "entity_kind": { "const": "model_configuration" }, "interaction_policy": { "const": "direct_prompt" }, "configuration_passport_class": { "const": "model-configuration-v1" } } },
        { "properties": { "entity_kind": { "const": "agent_system" }, "interaction_policy": { "const": "agentic" }, "configuration_passport_class": { "const": "agent-system-v1" } } },
        { "properties": { "entity_kind": { "const": "system_configuration" }, "interaction_policy": { "const": "system" }, "configuration_passport_class": { "const": "system-configuration-v1" } } },
        { "properties": { "entity_kind": { "const": "component_configuration" }, "interaction_policy": { "const": "retrieval" }, "configuration_passport_class": { "const": "component-configuration-v1" } } },
        { "properties": { "entity_kind": { "const": "arena_system" }, "interaction_policy": { "const": "crowd_pairwise" }, "configuration_passport_class": { "const": "arena-system-v1" } } }
      ]
    },
    {
      "if": {
        "required": ["objective"],
        "properties": { "objective": { "const": "lowest_cost_within_top_set" } }
      },
      "then": { "required": ["usage_profile"] }
    },
    {
      "if": {
        "required": ["usage_profile"],
        "properties": {
          "usage_profile": {
            "allOf": [
              { "properties": { "basis": { "const": "estimated" } }, "required": ["basis"] },
              {
                "anyOf": [
                  { "properties": { "cached_read_tokens": { "minimum": 1 } }, "required": ["cached_read_tokens"] },
                  { "properties": { "cache_writes": { "minItems": 1 } }, "required": ["cache_writes"] },
                  { "properties": { "cache_storage_token_seconds": { "minimum": 1 } }, "required": ["cache_storage_token_seconds"] }
                ]
              }
            ]
          }
        }
      },
      "then": {
        "required": ["zero_cache_sensitivity_usage_profile"],
        "properties": {
          "zero_cache_sensitivity_usage_profile": {
            "properties": {
              "basis": { "const": "estimated" },
              "cached_read_tokens": { "const": 0 },
              "cache_writes": { "maxItems": 0 },
              "cache_storage_token_seconds": { "const": 0 }
            }
          }
        }
      },
      "else": { "not": { "required": ["zero_cache_sensitivity_usage_profile"] } }
    }
  ],
  "dependentRequired": {
    "monthly_budget_microusd": ["usage_profile"],
    "zero_cache_sensitivity_usage_profile": ["usage_profile"]
  },
  "$defs": {
    "NonEmptyString": { "type": "string", "minLength": 1 },
    "NonEmptyStringSet": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/NonEmptyString" }
    },
    "NonNegativeSafeInteger": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "PositiveSafeInteger": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
    "UsageProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "basis",
        "uncached_input_tokens",
        "cached_read_tokens",
        "output_tokens",
        "cache_writes",
        "cache_storage_token_seconds"
      ],
      "properties": {
        "basis": { "enum": ["measured", "estimated"] },
        "uncached_input_tokens": { "$ref": "#/$defs/NonNegativeSafeInteger" },
        "cached_read_tokens": { "$ref": "#/$defs/NonNegativeSafeInteger" },
        "output_tokens": { "$ref": "#/$defs/NonNegativeSafeInteger" },
        "cache_writes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/CacheWriteUsage" }
        },
        "cache_storage_token_seconds": { "$ref": "#/$defs/NonNegativeSafeInteger" }
      },
      "anyOf": [
        { "properties": { "uncached_input_tokens": { "minimum": 1 } }, "required": ["uncached_input_tokens"] },
        { "properties": { "cached_read_tokens": { "minimum": 1 } }, "required": ["cached_read_tokens"] },
        { "properties": { "output_tokens": { "minimum": 1 } }, "required": ["output_tokens"] },
        { "properties": { "cache_writes": { "minItems": 1 } }, "required": ["cache_writes"] }
      ]
    },
    "CacheWriteUsage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ttl_seconds", "tokens"],
      "properties": {
        "ttl_seconds": { "$ref": "#/$defs/PositiveSafeInteger" },
        "tokens": { "$ref": "#/$defs/PositiveSafeInteger" }
      }
    }
  }
}
