{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evalrank.ai/schemas/result-row.schema.json",
  "title": "EvalRank Result Row",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "object",
    "entity_id",
    "entity_kind",
    "benchmark_id",
    "benchmark_version",
    "harness",
    "harness_version",
    "is_self_reported",
    "n_items",
    "ci95",
    "score_raw",
    "score_unit",
    "date_run",
    "model_version",
    "provenance",
    "source_url",
    "attribution_string",
    "flags",
    "verification_state"
  ],
  "properties": {
    "object": {
      "const": "result_row"
    },
    "entity_id": {
      "type": "string",
      "minLength": 1
    },
    "entity_kind": {
      "type": "string",
      "enum": [
        "model",
        "tool_server",
        "agent"
      ]
    },
    "benchmark_id": {
      "type": "string",
      "minLength": 1
    },
    "benchmark_version": {
      "type": "string",
      "minLength": 1
    },
    "harness": {
      "type": "string",
      "minLength": 1
    },
    "harness_version": {
      "type": "string",
      "minLength": 1
    },
    "is_self_reported": {
      "type": "boolean"
    },
    "n_items": {
      "type": "integer",
      "minimum": 0
    },
    "ci95": {
      "type": "array",
      "prefixItems": [
        {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      ],
      "minItems": 2,
      "maxItems": 2
    },
    "score_raw": {
      "type": "number"
    },
    "score_unit": {
      "type": "string",
      "minLength": 1
    },
    "date_run": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "model_version": {
      "type": "string",
      "minLength": 1
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true
    },
    "source_url": {
      "type": "string",
      "format": "uri-reference",
      "minLength": 1
    },
    "attribution_string": {
      "type": "string",
      "minLength": 1
    },
    "flags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "saturated",
        "contaminated",
        "judge_model_dependent",
        "scaffold_nonstandard"
      ],
      "properties": {
        "saturated": {
          "type": "boolean"
        },
        "contaminated": {
          "type": "boolean"
        },
        "judge_model_dependent": {
          "type": "boolean"
        },
        "scaffold_nonstandard": {
          "type": "boolean"
        }
      }
    },
    "verification_state": {
      "type": "string",
      "enum": [
        "verified",
        "provisional"
      ]
    }
  }
}
