{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evalrank.ai/schemas/ranked-entity.schema.json",
  "title": "EvalRank Ranked Entity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entity_type",
    "id",
    "rank",
    "capability_score",
    "confidence",
    "ci95",
    "methodology_version",
    "trust_tier",
    "score_components",
    "axes",
    "freshness",
    "caveats"
  ],
  "properties": {
    "entity_type": {
      "type": "string",
      "minLength": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "rank": {
      "type": "integer",
      "minimum": 1
    },
    "capability_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "ci95": {
      "type": "array",
      "prefixItems": [
        {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      ],
      "minItems": 2,
      "maxItems": 2
    },
    "methodology_version": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}\\.[1-9]\\d*\\.([a-z0-9]+-)*[a-z0-9]+$"
    },
    "trust_tier": {
      "type": "string",
      "enum": [
        "verified",
        "standardized",
        "self-reported",
        "tracking-only"
      ]
    },
    "score_components": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      }
    },
    "axes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence"
      ],
      "properties": {
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "n_items",
            "coverage"
          ],
          "properties": {
            "n_items": {
              "type": "integer",
              "minimum": 0
            },
            "coverage": {
              "type": "string",
              "enum": [
                "verified",
                "standardized",
                "self-reported",
                "tracking-only"
              ]
            }
          }
        }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "last_eval",
        "next_refresh",
        "status"
      ],
      "properties": {
        "last_eval": {
          "type": "string",
          "minLength": 1
        },
        "next_refresh": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "fresh",
            "stale",
            "recalibrating"
          ]
        }
      }
    },
    "caveats": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
