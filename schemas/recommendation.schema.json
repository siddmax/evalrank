{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evalrank.ai/schemas/recommendation.schema.json",
  "title": "EvalRank Recommendation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "object",
    "use_case",
    "shortlist_depth",
    "depth_rationale",
    "degraded",
    "served_from",
    "base_snapshot_lag_ms",
    "methodology_version",
    "generated_at",
    "comparability",
    "ranked",
    "groups",
    "the_call",
    "abstention",
    "exclusions",
    "recommendation_id",
    "recommend_id",
    "search_run_id",
    "request_id"
  ],
  "properties": {
    "object": {
      "const": "recommendation"
    },
    "use_case": {
      "type": "string",
      "minLength": 1
    },
    "shortlist_depth": {
      "type": "integer",
      "minimum": 0
    },
    "depth_rationale": {
      "type": "string",
      "minLength": 1
    },
    "degraded": {
      "type": "boolean"
    },
    "served_from": {
      "type": "string",
      "minLength": 1
    },
    "base_snapshot_lag_ms": {
      "type": "integer",
      "minimum": 0
    },
    "methodology_version": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}\\.[1-9]\\d*\\.([a-z0-9]+-)*[a-z0-9]+$"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "comparability": {
      "type": "string",
      "enum": [
        "single-scale",
        "kind-grouped"
      ]
    },
    "ranked": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "ranked-entity.schema.json"
      }
    },
    "groups": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "#/$defs/RankingGroup"
      }
    },
    "the_call": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "decision",
        "confidence",
        "reason",
        "abstention_reason"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "enum": [
            "recommend",
            "abstain"
          ]
        },
        "confidence": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "abstention_reason": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "decision": {
                "const": "recommend"
              }
            },
            "required": [
              "decision"
            ]
          },
          "then": {
            "properties": {
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "abstention_reason": {
                "const": null
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "decision": {
                "const": "abstain"
              }
            },
            "required": [
              "decision"
            ]
          },
          "then": {
            "properties": {
              "confidence": {
                "const": null
              },
              "abstention_reason": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ]
    },
    "abstention": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "reason",
        "detail"
      ],
      "properties": {
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "detail": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "exclusions": {
      "type": "array",
      "items": {
        "$ref": "exclusion.schema.json"
      }
    },
    "recommendation_id": {
      "type": "string",
      "pattern": "^rec_[0-9a-f]{24}$"
    },
    "recommend_id": {
      "type": "string",
      "pattern": "^rec_[0-9a-f]{24}$"
    },
    "search_run_id": {
      "type": "string",
      "pattern": "^rec_[0-9a-f]{24}$"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "comparability": {
            "const": "single-scale"
          }
        },
        "required": [
          "comparability"
        ]
      },
      "then": {
        "properties": {
          "groups": {
            "const": null
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "comparability": {
            "const": "kind-grouped"
          }
        },
        "required": [
          "comparability"
        ]
      },
      "then": {
        "properties": {
          "ranked": {
            "maxItems": 0
          },
          "groups": {
            "type": "array",
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "the_call": {
            "type": "object",
            "properties": {
              "decision": {
                "const": "abstain"
              }
            },
            "required": [
              "decision"
            ]
          }
        },
        "required": [
          "the_call"
        ]
      },
      "then": {
        "required": [
          "abstention"
        ],
        "properties": {
          "abstention": {
            "type": "object"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "the_call": {
            "type": "object",
            "properties": {
              "decision": {
                "const": "recommend"
              }
            },
            "required": [
              "decision"
            ]
          }
        },
        "required": [
          "the_call"
        ]
      },
      "then": {
        "required": [
          "abstention"
        ],
        "properties": {
          "abstention": {
            "const": null
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "abstention": {
            "type": "object"
          }
        },
        "required": [
          "abstention"
        ]
      },
      "then": {
        "required": [
          "the_call"
        ],
        "properties": {
          "the_call": {
            "type": "object",
            "properties": {
              "decision": {
                "const": "abstain"
              }
            },
            "required": [
              "decision"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "abstention": {
            "type": "object"
          }
        },
        "required": [
          "abstention"
        ]
      },
      "then": {
        "properties": {
          "comparability": {
            "const": "single-scale"
          },
          "shortlist_depth": {
            "const": 0
          },
          "ranked": {
            "maxItems": 0
          },
          "groups": {
            "const": null
          }
        }
      }
    }
  ],
  "$defs": {
    "RankingGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object",
        "group_key",
        "entity_type",
        "ranked",
        "group_rationale"
      ],
      "properties": {
        "object": {
          "const": "ranking_group"
        },
        "group_key": {
          "type": "string",
          "minLength": 1
        },
        "entity_type": {
          "type": "string",
          "minLength": 1
        },
        "ranked": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "ranked-entity.schema.json"
          }
        },
        "group_rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
